---
import { Markdown } from "astro-remote";
import { SERVER_URL } from '../../consts';
import BlogPost from '../../layouts/BlogPost.astro';
import fetchApi from '../../lib/strapi';
import type Article from '../../interfaces/article';

export async function getStaticPaths() {
  const posts = await fetchApi<Article[]>({
    endpoint: 'posts?populate=media',
    wrappedByKey: 'data',
  });

  const staticPaths = posts.map((post) => ({
    params: { slug: post.attributes?.slug ?? String(post.id) },
    props: { post }
  }));

  return staticPaths;
}

const slug = Astro.params.slug;
let post = Astro.props?.post;

if (!post) {
  // Try fetching by slug
  post = await fetchApi<any>({
    endpoint: `posts?filters[slug]=${slug}&populate=media`,
    wrappedByKey: 'data',
    wrappedByList: true,
  }).catch(() => null);

  // If not found and slug looks like an id, try fetching by id
  if (!post && /^\d+$/.test(slug)) {
    const res = await fetchApi<any>({ endpoint: `posts/${slug}?populate=media` }).catch(() => null);
    post = res?.data ?? res;
  }
}

if (!post) {
  throw new Error(`Post not found: ${slug}`);
}

const { title, description, publishedAt, media, content, updatedAt } = post.attributes || {};
const heroImage = media?.data?.attributes ? SERVER_URL + media.data.attributes.url : undefined;
---

<BlogPost title={title} description={description} pubDate={new Date(publishedAt)} heroImage={heroImage}>
  <Markdown content={content} />
</BlogPost>
